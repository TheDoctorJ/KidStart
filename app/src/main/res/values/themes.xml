<resources>
    <style name="KidStartTheme" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/surface_soft</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/text_secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSecondaryContainer">@color/surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/purple_primary_light</item>
        <item name="colorOnTertiary">@color/text_on_primary</item>
        <item name="colorTertiaryContainer">@color/surface_soft</item>
        <item name="colorOnTertiaryContainer">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Outline -->
        <item name="colorOutline">@color/stroke</item>
        <item name="colorOutlineVariant">@color/divider</item>

        <!-- Inverse -->
        <item name="colorSurfaceInverse">@color/text_primary</item>
        <item name="colorOnSurfaceInverse">@color/surface</item>
        <item name="colorPrimaryInverse">@color/purple_primary_light</item>

        <!-- Fixed colors -->
        <item name="colorPrimaryFixed">@color/purple_primary</item>
        <item name="colorOnPrimaryFixed">@color/text_on_primary</item>
        <item name="colorPrimaryFixedDim">@color/purple_primary_dark</item>
        <item name="colorOnPrimaryFixedVariant">@color/text_on_primary</item>

        <item name="colorSecondaryFixed">@color/text_secondary</item>
        <item name="colorOnSecondaryFixed">@color/text_on_primary</item>
        <item name="colorSecondaryFixedDim">@color/text_hint</item>
        <item name="colorOnSecondaryFixedVariant">@color/text_primary</item>

        <item name="colorTertiaryFixed">@color/purple_primary_light</item>
        <item name="colorOnTertiaryFixed">@color/text_on_primary</item>
        <item name="colorTertiaryFixedDim">@color/purple_primary</item>
        <item name="colorOnTertiaryFixedVariant">@color/text_on_primary</item>

        <!-- Surface containers -->
        <item name="colorSurfaceDim">@color/surface_variant</item>
        <item name="colorSurfaceBright">@color/surface</item>
        <item name="colorSurfaceContainerLowest">@color/surface</item>
        <item name="colorSurfaceContainerLow">@color/bg_main</item>
        <item name="colorSurfaceContainer">@color/surface_soft</item>
        <item name="colorSurfaceContainerHigh">@color/surface_variant</item>
        <item name="colorSurfaceContainerHighest">@color/divider</item>

        <item name="android:statusBarColor">@color/ic_launcher_background</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>
</resources>